# ─────────────────────────────────────────────
# Spay Backend — environment variables
# Copy this file to `.env` and fill in real values.
# [PROD-REQUIRED] = the process refuses to boot in production if missing
# (no insecure fallback). Dev has convenient localhost/dev defaults.
# ─────────────────────────────────────────────

# Server. NODE_ENV MUST be exactly "production" in prod — it gates secure
# cookies, hidden error stacks, combined logging, and register-secret enforcement.
PORT=4000
NODE_ENV=development

# MongoDB — [PROD-REQUIRED]
# Local example:  mongodb://localhost:27017/spay
# Atlas example:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/spay?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/spay

# Auth (single env user + any DB users). ADMIN_EMAIL is [PROD-REQUIRED].
# Generate ADMIN_PASSWORD_HASH via `npm run create-admin -- <password>`
ADMIN_EMAIL=admin@spay.finance
ADMIN_PASSWORD_HASH=$2a$10$REPLACE_WITH_BCRYPT_HASH

# JWT signing secret — [PROD-REQUIRED]. Long random string, e.g. `openssl rand -hex 48`.
JWT_SECRET=replace-this-with-a-long-random-string
JWT_EXPIRES_IN=7d

# CORS allow-list — [PROD-REQUIRED]. Exact origins of the two frontends.
CMS_ORIGIN=http://localhost:3001
WEBSITE_ORIGIN=http://localhost:3000

# Public URL of this API (absolute links / uploads).
PUBLIC_URL=http://localhost:4000

# Instant ISR revalidation on publish (optional). URL = website's revalidate
# route; the secret must match the website's WEBSITE_REVALIDATE_SECRET.
WEBSITE_REVALIDATE_URL=http://localhost:3000/api/revalidate
WEBSITE_REVALIDATE_SECRET=replace-with-shared-secret

# Shared secret for the website's runtime page auto-registration (optional).
# Must match SPAY_REGISTER_SECRET on the website. Unset → allowed only in dev.
SPAY_REGISTER_SECRET=replace-with-shared-secret

# Cloudinary — media storage (https://console.cloudinary.com/app/settings/api-keys)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
