# ─────────────────────────────────────────────
# Spay Backend — environment variables
# Copy this file to `.env` and fill in real values.
# ─────────────────────────────────────────────

# Server
PORT=4000
NODE_ENV=development

# MongoDB — paste your connection string here when ready
# Local example:  mongodb://localhost:27017/spay
# Atlas example:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/spay?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/spay

# Auth (single user). Generate a hash via `npm run create-admin -- <password>`
ADMIN_EMAIL=admin@spay.finance
ADMIN_PASSWORD_HASH=$2a$10$REPLACE_WITH_BCRYPT_HASH

# JWT signing secret — use a long random string in production
JWT_SECRET=replace-this-with-a-long-random-string
JWT_EXPIRES_IN=7d

# CORS — comma-separated allowed origins
CMS_ORIGIN=http://localhost:3001
WEBSITE_ORIGIN=http://localhost:3000

# Public URL for built assets (uploads, etc.) when served from this backend
PUBLIC_URL=http://localhost:4000

# On-content-change revalidation
WEBSITE_REVALIDATE_URL=http://localhost:3000/api/revalidate
WEBSITE_REVALIDATE_SECRET=replace-with-shared-secret

# Cloudinary — media storage (get from https://console.cloudinary.com/app/settings/api-keys)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
