NODE_ENV=development
PORT=4000
MONGO_URI=mongodb://localhost:27017/spay_cms
CMS_ORIGIN=http://localhost:3000
PUBLIC_SITE_ORIGIN=http://localhost:3001
AUTOSAVE_MIN_INTERVAL_MS=1500
LOG_LEVEL=info
# Path to the spay-website project (used to auto-discover which sections exist).
# Resolved relative to cms-backend/ if not absolute.
SPAY_WEBSITE_PATH=../spay-website
SECTION_MANIFEST_CACHE_MS=30000
