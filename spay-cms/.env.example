# ─────────────────────────────────────────────
# Spay CMS (admin panel) — environment variables
# Copy to `.env.local` and fill in.
#
# IMPORTANT: NEXT_PUBLIC_* vars are inlined at BUILD time. Set them BEFORE
# running `next build` — changing them only at runtime has no effect.
# ─────────────────────────────────────────────

# Backend API origin (the Express server).
NEXT_PUBLIC_API_URL=http://localhost:4000

# Public website origin — used for the live-preview iframe, the "Preview" /
# "View live" links, and the canonical-URL preview.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
